# 账号（脚本登录/巡检）
AURA_ADMIN_USER=admin
AURA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# 基础镜像（企业网络可替换为内网镜像仓库地址）
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
PYTHON_BASE_IMAGE=python:3.11-slim
# 与 global.json 中 sdk.version 一致；企业内网可改为私服同源标签
DOTNET_SDK_IMAGE=mcr.microsoft.com/dotnet/sdk:10.0.201
DOTNET_ASPNET_IMAGE=mcr.microsoft.com/dotnet/aspnet:10.0.201

# PostgreSQL
POSTGRES_DB=aura
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_DEV_PASSWORD

# 安全项（示例值必须替换）
JWT_KEY=REPLACE_WITH_LONG_RANDOM_JWT_KEY
HMAC_SECRET=REPLACE_WITH_LONG_RANDOM_HMAC_SECRET

# AI 配置
# ArangoDB（用于替代 Milvus 的向量存储）
ARANGO_URI=http://arangodb:8529
ARANGO_DB=aura
ARANGO_USER=_system
ARANGO_ROOT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
ARANGO_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
AURA_MODEL_PATH=/app/models/osnet_ibn_x1_0.onnx

# API 运行环境：本地联调常用 Development；Ubuntu 一键部署脚本 deploy-aura-ubuntu.sh 写入 Production
# ASPNETCORE_ENVIRONMENT=Development

# 联调 compose 使用命名卷 aura-api-storage 挂载 /app/storage（见 docker-compose.full.example.yml）；docker compose down 默认保留卷
