# 账号（脚本登录/巡检）
AURA_ADMIN_USER=admin
AURA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# 基础镜像（企业网络可替换为内网镜像仓库地址）
MYSQL_IMAGE=mysql:8.0
REDIS_IMAGE=redis:7-alpine
PYTHON_BASE_IMAGE=python:3.11-slim
DOTNET_SDK_IMAGE=mcr.microsoft.com/dotnet/sdk:10.0-preview
DOTNET_ASPNET_IMAGE=mcr.microsoft.com/dotnet/aspnet:10.0-preview

# MySQL
MYSQL_ROOT_PASSWORD=REPLACE_ROOT_PASSWORD
MYSQL_DATABASE=aura
MYSQL_USER=dev_user
MYSQL_PASSWORD=REPLACE_DEV_PASSWORD

# 安全项（示例值必须替换）
JWT_KEY=REPLACE_WITH_LONG_RANDOM_JWT_KEY
HMAC_SECRET=REPLACE_WITH_LONG_RANDOM_HMAC_SECRET

# AI 配置
MILVUS_URI=http://127.0.0.1:19530
AURA_MODEL_PATH=/app/models/osnet_ibn_x1_0.onnx
