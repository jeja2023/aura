# 生产环境变量模板（示例，占位值必须替换）

# 基础镜像（建议改为企业私有仓库镜像）
MYSQL_IMAGE=mysql:8.0
REDIS_IMAGE=redis:7-alpine
PYTHON_BASE_IMAGE=python:3.11-slim
DOTNET_SDK_IMAGE=mcr.microsoft.com/dotnet/sdk:10.0-preview
DOTNET_ASPNET_IMAGE=mcr.microsoft.com/dotnet/aspnet:10.0-preview
API_IMAGE=your-registry/aura-api:REPLACE_TAG
AI_IMAGE=your-registry/aura-ai:REPLACE_TAG

# 基础连接
CONNECTIONSTRINGS__MYSQL=server=mysql;port=3306;database=aura;uid=prod_user;pwd=REPLACE_ME;AllowPublicKeyRetrieval=False
CONNECTIONSTRINGS__REDIS=redis:6379,password=REPLACE_ME
AI__BASEURL=http://ai:8000

# 安全密钥
JWT__KEY=REPLACE_WITH_LONG_RANDOM_JWT_KEY
SECURITY__HMACSECRET=REPLACE_WITH_LONG_RANDOM_HMAC_SECRET

# 告警通知
OPS__ALERT__WEBHOOKURL=
OPS__ALERT__FILEPATH=/app/storage/logs/alert-notify.log

# 巡检账号（仅用于自动化巡检脚本）
AURA_ADMIN_USER=admin
AURA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# AI 运行配置
MILVUS_URI=http://milvus:19530
AURA_MODEL_PATH=/models/osnet_ibn_x1_0.onnx
