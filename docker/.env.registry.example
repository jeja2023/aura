# 私有仓库与离线分发变量模板（示例）

# 仓库登录
REGISTRY_HOST=registry.local
REGISTRY_USER=REPLACE_ME
REGISTRY_PASSWORD=REPLACE_ME

# 业务镜像仓库
API_IMAGE_REPO=registry.local/aura/aura-api
AI_IMAGE_REPO=registry.local/aura/aura-ai
IMAGE_TAG=v0.0.6

# 离线镜像包路径
IMAGE_ARCHIVE_DIR=docker/dist
IMAGE_ARCHIVE_FILE=docker/dist/aura-images-v0.0.6.tar
