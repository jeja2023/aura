{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "Jwt": {
    "Key": "PLEASE_SET_IN_ENV_OR_APPSETTINGS_DEVELOPMENT",
    "Issuer": "Aura.Api",
    "Audience": "Aura.Client",
    "ExpireMinutes": 480
  },
  "Security": {
    "HmacSecret": "PLEASE_SET_IN_ENV_OR_APPSETTINGS_DEVELOPMENT",
    "CaptureIpWhitelist": [
      "::1",
      "127.0.0.1"
    ],
    "CspPolicy": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ws: wss:;"
  },
  "Ai": {
    "BaseUrl": "http://127.0.0.1:8000",
    "ApiKey": ""
  },
  "Paths": {
    "FrontendRoot": ""
  },
  "Storage": {
    "CaptureRetryRoot": "",
    "SaveCaptureImageOnSuccess": true
  },
  "CaptureRetry": {
    "PreferInlineBase64": false,
    "AllowInlineBase64Fallback": false
  },
  "Ops": {
    "Alert": {
      "WebhookUrl": "",
      "FilePath": "storage/logs/alert-notify.log",
      "HealthFailIfRecentFailureMinutes": 10
    },
    "Metrics": {
      "ExposePrometheus": true
    },
    "Telemetry": {
      "EnableTracing": false,
      "OtlpEndpoint": "",
      "OtlpProtocol": "Grpc",
      "ServiceName": "Aura.Api"
    }
  },
  "ConnectionStrings": {
    "PgSql": "PLEASE_SET_CONNECTIONSTRING_PGSQL",
    "Redis": "PLEASE_SET_CONNECTIONSTRING_REDIS"
  },
  // 生产环境请在 appsettings.Production.json 或环境中将 AllowedHosts 改为实际域名（分号分隔），避免长期使用 *。
  "AllowedHosts": "*",
  "HttpClients": {
    "Ai": {
      "TotalRequestTimeoutSeconds": 120,
      "AttemptTimeoutSeconds": 90,
      "MaxRetryAttempts": 2
    },
    "AlertNotifier": {
      "TotalRequestTimeoutSeconds": 30,
      "AttemptTimeoutSeconds": 15,
      "MaxRetryAttempts": 2
    }
  },
  "Aura": {
    "AllowInMemoryDataFallback": false
  },
  // 与 Hikvision:Isapi:GatewayMaxRequestBodyBytes 等大请求对齐，避免 Kestrel 默认限制与业务校验不一致。
  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 10485760
    }
  },
  // 海康 ISAPI：生产环境凭据请用环境变量（如 Hikvision__Isapi__DefaultPassword）或 DefaultPasswordEnvironmentVariable 指向的变量注入，勿将真实密码写入仓库。
  "Hikvision": {
    "Isapi": {
      "RequestTimeoutSeconds": 10,
      "SnapShotImageType": "JPEG",
      "UseHttps": false,
      "SkipSslCertificateValidation": false,
      "AllowInsecureDeviceTls": false,
      "DefaultUserName": "",
      "DefaultPassword": "",
      "DefaultUserNameEnvironmentVariable": "",
      "DefaultPasswordEnvironmentVariable": "",
      "MaxSnapshotBytes": 10485760,
      "MaxSdtPictureUploadBytes": 10485760,
      "GatewayEnabled": true,
      "GatewayTimeoutSeconds": 120,
      "GatewayMaxPathLength": 2048,
      "GatewayMaxRequestBodyBytes": 10485760,
      "GatewayMaxResponseTextChars": 5000000,
      "GatewayMaxResponseBinaryBytes": 52428800,
      "GatewayAuditLogEnabled": true,
      "GatewayIncludeDeviceErrorBodyIn502": true,
      "GatewayDeviceErrorBodyLogMaxChars": 512,
      "GatewayMaxRequestsPerMinute": 0,
      "TelemetryActivitiesEnabled": true,
      "DeviceApiIncludeErrorBodyIn502": true,
      "DeviceApiAuditLogEnabled": true,
      "DeviceApiMaxRequestsPerMinute": 0,
      "ConnectivityProbeTimeoutSeconds": 0,
      "AlertStream": {
        "Enabled": false,
        "DeviceIds": [],
        "PathAndQuery": "/ISAPI/Event/notification/alertStream",
        "ReconnectSeconds": 10,
        "SupervisorRefreshSeconds": 30,
        "MaxBufferBytes": 16777216,
        "PushSignalR": true,
        "IngestCaptureEnabled": true,
        "MaxImageBytes": 10485760,
        "AllowCameraChannelFallback": true,
        "CameraChannelFallbackStrategy": "first",
        "DedupWindowSeconds": 3,
        "XmlPreviewMaxChars": 4096,
        "LogHeartbeats": false
      }
    }
  }
}
