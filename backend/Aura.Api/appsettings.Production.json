{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Aura.Api": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "Jwt": {
    "Key": "PLEASE_REPLACE_WITH_STRONG_PROD_KEY_MIN_32_CHARS",
    "Issuer": "Aura.Api.Prod",
    "Audience": "Aura.Client.Prod",
    "ExpireMinutes": 120
  },
  "Security": {
    "HmacSecret": "PLEASE_REPLACE_WITH_PROD_HMAC_SECRET",
    "CaptureIpWhitelist": [
      "10.0.0.10",
      "10.0.0.11"
    ],
    "CspPolicy": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self';"
  },
  "Ai": {
    "BaseUrl": "http://10.0.1.20:8000",
    "ApiKey": ""
  },
  "Paths": {
    "FrontendRoot": "/opt/aura/frontend"
  },
  "Storage": {
    "CaptureRetryRoot": "",
    "SaveCaptureImageOnSuccess": true
  },
  "CaptureRetry": {
    "PreferInlineBase64": false,
    "AllowInlineBase64Fallback": false
  },
  "Ops": {
    "Alert": {
      "WebhookUrl": "https://please-replace-alert-webhook.example.com/hook",
      "FilePath": "storage/logs/alert-notify.prod.log",
      "HealthFailIfRecentFailureMinutes": 30
    },
    "Metrics": {
      "ExposePrometheus": false
    },
    "Telemetry": {
      "EnableTracing": false,
      "OtlpEndpoint": "",
      "OtlpProtocol": "Grpc",
      "ServiceName": "Aura.Api"
    }
  },
  "ConnectionStrings": {
    "PgSql": "PLEASE_SET_CONNECTIONSTRING_PGSQL",
    "Redis": "PLEASE_SET_CONNECTIONSTRING_REDIS"
  },
  "Aura": {
    "AllowInMemoryDataFallback": false
  },
  "AllowedHosts": "please-replace.your-aura-host.example.com",
  "HttpClients": {
    "Ai": {
      "TotalRequestTimeoutSeconds": 180,
      "AttemptTimeoutSeconds": 120,
      "MaxRetryAttempts": 2
    },
    "AlertNotifier": {
      "TotalRequestTimeoutSeconds": 30,
      "AttemptTimeoutSeconds": 15,
      "MaxRetryAttempts": 2
    }
  },
  "Hikvision": {
    "Isapi": {
      "GatewayMaxRequestsPerMinute": 60,
      "DeviceApiMaxRequestsPerMinute": 120
    }
  }
}
