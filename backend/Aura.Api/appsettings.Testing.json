{
  // 维护提示：若修改本文件中 Jwt:Key、Jwt:Issuer、Jwt:Audience，请同步更新 backend/Aura.Api.Integration.Tests/TestingJwt.cs 内对应常量，否则集成测试会失败。
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning",
      "Aura.Api.Cache": "Error"
    }
  },
  "Jwt": {
    "Key": "aura-integration-test-jwt-signing-key-min-32-chars",
    "Issuer": "Aura.Api.Testing",
    "Audience": "Aura.Client.Testing",
    "ExpireMinutes": 60
  },
  "Security": {
    "HmacSecret": "aura-integration-test-hmac-secret-not-for-prod",
    "CaptureIpWhitelist": []
  },
  "Ai": {
    "BaseUrl": "http://127.0.0.1:1"
  },
  "ConnectionStrings": {
    "PgSql": "",
    "Redis": ""
  },
  "Aura": {
    "AllowInMemoryDataFallback": true
  },
  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 10485760
    }
  },
  "Hikvision": {
    "Isapi": {
      "RequestTimeoutSeconds": 10,
      "SnapShotImageType": "JPEG",
      "UseHttps": false,
      "SkipSslCertificateValidation": false,
      "AllowInsecureDeviceTls": false,
      "DefaultUserName": "",
      "DefaultPassword": "",
      "DefaultUserNameEnvironmentVariable": "",
      "DefaultPasswordEnvironmentVariable": "",
      "MaxSnapshotBytes": 10485760,
      "MaxSdtPictureUploadBytes": 10485760,
      "GatewayEnabled": true,
      "GatewayTimeoutSeconds": 120,
      "GatewayMaxPathLength": 2048,
      "GatewayMaxRequestBodyBytes": 10485760,
      "GatewayMaxResponseTextChars": 5000000,
      "GatewayMaxResponseBinaryBytes": 52428800,
      "GatewayAuditLogEnabled": false,
      "GatewayIncludeDeviceErrorBodyIn502": true,
      "GatewayDeviceErrorBodyLogMaxChars": 512,
      "GatewayMaxRequestsPerMinute": 0,
      "TelemetryActivitiesEnabled": false,
      "DeviceApiIncludeErrorBodyIn502": true,
      "DeviceApiAuditLogEnabled": false,
      "DeviceApiMaxRequestsPerMinute": 0,
      "ConnectivityProbeTimeoutSeconds": 0,
      "AlertStream": {
        "Enabled": false,
        "DeviceIds": [],
        "PathAndQuery": "/ISAPI/Event/notification/alertStream",
        "ReconnectSeconds": 10,
        "SupervisorRefreshSeconds": 30,
        "MaxBufferBytes": 16777216,
        "PushSignalR": false,
        "IngestCaptureEnabled": true,
        "MaxImageBytes": 10485760,
        "AllowCameraChannelFallback": true,
        "CameraChannelFallbackStrategy": "first",
        "DedupWindowSeconds": 3,
        "XmlPreviewMaxChars": 4096,
        "LogHeartbeats": false
      }
    }
  },
  "Ops": {
    "Metrics": {
      "ExposePrometheus": false
    },
    "Telemetry": {
      "EnableTracing": false,
      "OtlpEndpoint": ""
    }
  }
}
