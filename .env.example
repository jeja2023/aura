#-------------------------------
# Aura 管理员登录配置（后端 .NET）
#-------------------------------
# 管理员用户名
AURA_ADMIN_USER=admin
# 管理员密码（建议替换为强密码）
AURA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

#-------------------------------
# JWT / HMAC（后端 .NET: 用于鉴权与 readiness）
#-------------------------------
# Jwt Key：只要不是空、也不包含 aura-dev-jwt-key-please-change 这段字符串即可通过 readiness
Jwt__Key=REPLACE_WITH_LONG_RANDOM_JWT_KEY_MIN_32_CHARS
# HmacSecret：只要不是空、也不包含 demo-hmac-secret 即可通过 readiness
Security__HmacSecret=REPLACE_WITH_LONG_RANDOM_HMAC_SECRET

#-------------------------------
# PostgreSQL 配置（后端 .NET: ConnectionStrings__PgSql）
#-------------------------------
# 连接串格式：Host=...;Port=5432;Database=aura;Username=...;Password=...
ConnectionStrings__PgSql=Host=127.0.0.1;Port=5432;Database=aura;Username=postgres;Password=REPLACE_DEV_PASSWORD

#-------------------------------
# Redis 配置（后端 .NET: ConnectionStrings__Redis）
#-------------------------------
# Redis 连接串：127.0.0.1:6379,password=...（如果未设置密码可去掉 password=...）
ConnectionStrings__Redis=127.0.0.1:6379,password=REPLACE_REDIS_PASSWORD

#-------------------------------
# ArangoDB 配置（AI 服务: ARANGO_*）
#-------------------------------
# ArangoDB HTTP 地址（默认 http://127.0.0.1:8529）
ARANGO_URI=http://127.0.0.1:8529
# AI 使用的数据库名（默认 aura）
ARANGO_DB=aura
# ArangoDB 用户（你项目默认本地使用 root）
ARANGO_USER=root
# ArangoDB 用户密码（例如 root 的密码）
ARANGO_PASSWORD=REPLACE_ARANGO_PASSWORD
# 生产环境建议保持 true，避免 AI 服务在 ArangoDB 不可用时静默降级到内存索引
AURA_AI_REQUIRE_ARANGO=false

#-------------------------------
# 后端调用 AI（.NET: Ai__BaseUrl / Ai__ApiKey）
#-------------------------------
Ai__BaseUrl=http://127.0.0.1:8000
# 与 AURA_API_KEY 一致且非空时由 .NET 自动附加请求头 X-Aura-Ai-Key
Ai__ApiKey=

#-------------------------------
# .NET 运行时（本机联调常用 Development；缺省亦可由 launchSettings 决定）
#-------------------------------
ASPNETCORE_ENVIRONMENT=Development

#-------------------------------
# AI 访问控制（可选；非空须与 Ai__ApiKey 一致）
#-------------------------------
AURA_API_KEY=
# 仅当模型不在默认路径时设置，例如：AURA_MODEL_PATH=E:\Aura\ai\models\osnet_ibn_x1_0.onnx

#-------------------------------
# 可观测性（可选；本地未用时保持本节为空即可）
#-------------------------------
# Ops__Metrics__ExposePrometheus=true
# Ops__Telemetry__EnableTracing=false
# Ops__Telemetry__OtlpEndpoint=http://127.0.0.1:4317
# Ops__Telemetry__OtlpProtocol=Grpc
# 需要 Prometheus / OpenTelemetry 等时，见 README「关键接口」与 CHANGELOG 中 Ops说明。
