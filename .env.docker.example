# Docker deployment environment template. Copy this file as .env.docker.

# Image policy:
# - never: use images already loaded on this host; fail if missing. Recommended after the server is disconnected.
# - missing: allow pulling missing images while the server is temporarily online or connected to an internal registry.
IMAGE_PULL_POLICY=never

# Runtime images. Use local image tags or internal registry image URLs.
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
ARANGO_IMAGE=arangodb:3.12
API_IMAGE=aura-api:local
AI_IMAGE=aura-ai:local

# Build base images. These must also be locally available or reachable from your internal registry when building.
PYTHON_BASE_IMAGE=python:3.11-slim
DOTNET_SDK_IMAGE=mcr.microsoft.com/dotnet/sdk:10.0.201
DOTNET_ASPNET_IMAGE=mcr.microsoft.com/dotnet/aspnet:10.0.201

# Published ports.
API_PORT=5000
AI_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
ARANGO_PORT=8529

# Bind addresses. Internet-facing deployments should keep databases/cache/AI on 127.0.0.1.
API_BIND_ADDRESS=0.0.0.0
AI_BIND_ADDRESS=127.0.0.1
POSTGRES_BIND_ADDRESS=127.0.0.1
REDIS_BIND_ADDRESS=127.0.0.1
ARANGO_BIND_ADDRESS=127.0.0.1

# ASP.NET host allow-list. Use semicolons for multiple values, for example: aura.lan;192.168.10.50
ALLOWEDHOSTS=REPLACE_AURA_HOST_OR_IP

# PostgreSQL container initialization.
POSTGRES_DB=aura
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_POSTGRES_PASSWORD

# ArangoDB container initialization. By default AI connects as root.
ARANGO_ROOT_PASSWORD=REPLACE_ARANGO_ROOT_PASSWORD
ARANGO_DB=aura
ARANGO_USER=root
AURA_AI_REQUIRE_ARANGO=true

# Optional shared AI API key. Non-empty values must match on API and AI.
AURA_API_KEY=

# SignalR Redis backplane. Keep false for a single API container.
SIGNALR__REDISBACKPLANE__ENABLED=false
SIGNALR__REDISBACKPLANE__CHANNELPREFIX=aura:signalr

# Security secrets. Replace all placeholders before deployment.
JWT__KEY=REPLACE_WITH_LONG_RANDOM_JWT_KEY
SECURITY__HMACSECRET=REPLACE_WITH_LONG_RANDOM_HMAC_SECRET

# Initial/admin account for checks.
AURA_ADMIN_USER=admin
AURA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Ops.
OPS__ALERT__WEBHOOKURL=
OPS__ALERT__FILEPATH=/app/storage/logs/alert-notify.log
OPS__METRICS__EXPOSEPROMETHEUS=false
OPS__TELEMETRY__ENABLETRACING=false
OPS__TELEMETRY__OTLPENDPOINT=
OPS__TELEMETRY__OTLPPROTOCOL=Grpc

# Host mounts. Relative paths are resolved from docker/docker-compose.yml.
AURA_MODEL_HOST_DIR=../models
AURA_MODEL_PATH=/app/models/osnet_ibn_x1_0.onnx
FRONTEND_HOST_DIR=../frontend
PATHS__FRONTENDROOT=/app/frontend
