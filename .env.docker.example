# Docker 部署环境变量模板。复制本文件为 .env.docker 后再按现场修改。

# 镜像拉取策略：
# - never：仅使用本机已有镜像，缺少镜像时直接失败；服务器断开互联网后推荐使用。
# - missing：临时联网部署或连接内网镜像仓库时，允许拉取本机缺失的镜像。
IMAGE_PULL_POLICY=never
COMPOSE_IGNORE_ORPHANS=true

# 容器与数据库会话时区。中国现场部署保持 Asia/Shanghai。
TZ=Asia/Shanghai
PG_TIMEZONE=Asia/Shanghai

# 运行时镜像。可以使用本地镜像标签，也可以使用内网镜像仓库地址。
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
ARANGO_IMAGE=arangodb:3.12
API_IMAGE=aura-api:local
AI_IMAGE=aura-ai:local

# 构建业务镜像使用的基础镜像。构建时这些镜像也必须在本机存在，或可从内网/互联网仓库拉取。
PYTHON_BASE_IMAGE=python:3.12-slim
DOTNET_SDK_IMAGE=mcr.microsoft.com/dotnet/sdk:10.0.201
DOTNET_ASPNET_IMAGE=mcr.microsoft.com/dotnet/aspnet:10.0

# 对外发布端口。
API_PORT=9003
AI_PORT=8000
# 启动兜底：API 直连外部 AI worker 时可填分号/逗号分隔地址；运行后优先在前端“运行配置”页面维护。
# 建议保持为空，仅在数据库运行时配置不可用时作为兜底；留空则使用 Compose 内置 ai 服务。
AI_BASE_URLS=
POSTGRES_PORT=5432
REDIS_PORT=6380
ARANGO_PORT=8529

# 端口监听地址。临时联网部署时，数据库、缓存和 AI 建议只监听 127.0.0.1。
API_BIND_ADDRESS=0.0.0.0
AI_BIND_ADDRESS=127.0.0.1
POSTGRES_BIND_ADDRESS=127.0.0.1
REDIS_BIND_ADDRESS=127.0.0.1
ARANGO_BIND_ADDRESS=127.0.0.1

# ASP.NET 允许访问的主机名或 IP。多个值用英文分号分隔，例如 aura.lan;192.168.10.50。
ALLOWEDHOSTS=REPLACE_AURA_HOST_OR_IP

# PostgreSQL 容器初始化配置。
POSTGRES_DB=aura
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_POSTGRES_PASSWORD

# ArangoDB 容器初始化配置。默认 AI 使用 root 账号连接。
ARANGO_ROOT_PASSWORD=REPLACE_ARANGO_ROOT_PASSWORD
ARANGO_DB=aura
ARANGO_USER=root
AURA_AI_REQUIRE_ARANGO=true

# 可选的 AI 调用密钥。非空时 API 与 AI 必须保持一致。
AURA_API_KEY=

# AI 推理与检索保护参数。生产环境按机器性能、GPU/CPU worker 数量和抓拍峰值压测后调整。
AURA_AI_INFER_BATCH_SIZE=16
AURA_AI_INFER_MAX_WAIT_SECONDS=0.05
AURA_AI_INFER_QUEUE_MAX_SIZE=256
AURA_AI_INFER_ENQUEUE_TIMEOUT_SECONDS=0.2
AURA_AI_SEARCH_RATE_LIMIT_PER_MINUTE=600
AURA_AI_BREAKER_FAIL_THRESHOLD=8
AURA_AI_BREAKER_OPEN_SECONDS=20
AURA_AI_HEALTH_VERBOSE=false
AURA_AI_EXTRACT_FILE_ROOTS=
AURA_AI_INDEX_SNAPSHOT_PATH=data/ai/local_index_snapshot.json
AURA_AI_MIN_SCORE_DEFAULT=-1.0
AURA_AI_CANDIDATE_MULTIPLIER_DEFAULT=8
AURA_AI_CANDIDATE_POOL_DEFAULT=0
AURA_AI_ANN_PROBE_DEFAULT=16
AURA_AI_RERANK_WINDOW_DEFAULT=30

# GPU 推理服务对接。docker-compose.yml 已内置默认值；仅当现场 GPU worker 地址、
# project_name、model_name 或 token 不一致时在 .env.docker 覆盖。
# GPU 服务按共享模型根目录下的 <project_name>/<model_name> 查找模型。
AURA_GPU_PREDICT_URLS=http://gpu-worker-0:8000/predict;http://gpu-worker-1:8000/predict
AURA_GPU_PROJECT_NAME=person_reid
AURA_GPU_MODEL_NAME=osnet_x1_0_v1.onnx
AURA_GPU_API_TOKEN=
AURA_GPU_TIMEOUT_SECONDS=10

# 数据库升级迁移参数。db-migrate 会使用 PostgreSQL advisory lock 防止并发升级。
DB_MIGRATION_COMMAND_TIMEOUT_SECONDS=300
DB_MIGRATION_LOCK_TIMEOUT_SECONDS=60

# SignalR Redis backplane。单个 API 容器部署时保持 false。
SIGNALR__REDISBACKPLANE__ENABLED=false
SIGNALR__REDISBACKPLANE__CHANNELPREFIX=aura:signalr

# 安全密钥。部署前必须替换所有占位值。
JWT__KEY=REPLACE_WITH_LONG_RANDOM_JWT_KEY
SECURITY__HMACSECRET=REPLACE_WITH_LONG_RANDOM_HMAC_SECRET

# 初始管理员账号与检查脚本使用的账号。
AURA_ADMIN_USER=admin
AURA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# 运维与可观测性配置。
OPS__ALERT__WEBHOOKURL=
OPS__ALERT__FILEPATH=/app/storage/logs/alert-notify.log
OPS__METRICS__EXPOSEPROMETHEUS=false
OPS__TELEMETRY__ENABLETRACING=false
OPS__TELEMETRY__OTLPENDPOINT=
OPS__TELEMETRY__OTLPPROTOCOL=Grpc

# 宿主机挂载路径。相对路径按 docker/docker-compose.yml 所在目录解析。
AURA_MODEL_HOST_DIR=../models
AURA_MODEL_PATH=/app/models/osnet_ibn_x1_0.onnx
FRONTEND_HOST_DIR=../frontend
PATHS__FRONTENDROOT=/app/frontend
